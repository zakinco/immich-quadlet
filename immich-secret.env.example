# immich-secret.env
# このファイルを immich-secret.env にコピーして値を設定してください。
# このファイル自体はGitHubに公開されます。実際の値は immich-secret.env に記載してください。
#
# cp immich-secret.env.example ~/.config/containers/systemd/immich-secret.env
# chmod 600 ~/.config/containers/systemd/immich-secret.env

# ============================================================
# パス設定（ホスト側の絶対パス）
# ============================================================

# 写真の保存先
UPLOAD_LOCATION=/srv/your-disk/immich/library

# PostgreSQLデータの保存先（ネットワーク共有不可）
DB_DATA_LOCATION=/srv/your-disk/immich/postgres

# 外部ライブラリのパス（手動で写真を追加するフォルダ）
EXTERNAL_PATH=/srv/your-disk/photos

# ============================================================
# パスワード設定
# ============================================================

# データベースパスワード（DB_PASSWORD と POSTGRES_PASSWORD は同じ値にすること）
DB_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
